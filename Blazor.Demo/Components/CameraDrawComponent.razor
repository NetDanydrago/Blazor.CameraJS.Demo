<div class="d-flex flex-column gap-3">
    <div class="d-flex flex-wrap gap-2">
        <button type="button" class="btn btn-primary" @onclick="StartCameraAsync">Iniciar camara</button>
        <button type="button" class="btn btn-outline-primary" @onclick="TakePhotoAsync">Tomar foto</button>


    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header">Camara</div>
                <div class="card-body">
                    <video @ref="VideoReference" autoplay playsinline class="w-100 border rounded" style="min-height: 280px;"></video>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header">Lienzo</div>
                <div class="card-body">
                    <canvas @ref="CanvasReference" width="640" height="480" class="w-100 border rounded" style="touch-action: none;"></canvas>
                </div>
            </div>

            
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-palette"></i>
                <label class="form-label mb-0" for="penColor">Color</label>
                <input id="penColor" type="color" class="form-control form-control-color" value="@PenColor" @onchange="OnPenColorChanged" title="Color lapiz" />
            </div>

            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-pen"></i>
                <label class="form-label mb-0" for="penThickness">Grosor</label>
                <input id="penThickness" type="range" class="form-range flex-grow-1" min="1" max="30" step="1" @bind="PenThickness" @bind:after="() => OnPenThicknessChanged()" />
                <span class="badge bg-secondary">@PenThickness</span>
            </div>

        </div>
    </div>
</div>